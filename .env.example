PORT=3000
OPEN_BROWSER=true

# Gemini API
# Get this key from Google AI Studio.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_ENABLED=true

# While the other groups are not deployed, keep this enabled.
MOCK_MODE=true

# External service URLs. Fill these when each group gives the final URL.
AUTH_SERVICE_URL=
CATALOG_SERVICE_URL=
ORDER_SERVICE_URL=
PAYMENT_SERVICE_URL=
INVENTORY_SERVICE_URL=
SHIPPING_SERVICE_URL=
NOTIFICATION_SERVICE_URL=
REPORTING_SERVICE_URL=
