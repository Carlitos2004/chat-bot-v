PORT=3010
OPEN_BROWSER=true

# Gemini API
# Get this key from Google AI Studio.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_ENABLED=true

#API KEY de supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# While the other groups are not deployed, keep this enabled. Apagado porque ya no es fase pruebas.
MOCK_MODE=false

# External service URLs. Fill these when each group gives the final URL.
AUTH_SERVICE_URL=
CATALOG_SERVICE_URL=
ORDER_SERVICE_URL=
PAYMENT_SERVICE_URL=
INVENTORY_SERVICE_URL=
SHIPPING_SERVICE_URL=
NOTIFICATION_SERVICE_URL=
REPORTING_SERVICE_URL=